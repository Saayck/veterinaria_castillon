# ============================================================
# Variables de entorno del backend consolidado.
# Copia este archivo a .env y ajusta los valores (NO commitear .env).
# ============================================================

# --- SQL Server (compartido por las 5 BDs) ---
SQLSERVER_HOST=host.docker.internal
SQLSERVER_PORT=1433
SQLSERVER_USERNAME=sa
SQLSERVER_PASSWORD=CAMBIA_ESTE_PASSWORD

# --- Seguridad ---
# Secreto JWT: minimo 32 caracteres. Generar uno unico por entorno.
JWT_SECRET=CAMBIA_ESTE_SECRETO_LARGO_MINIMO_32_CARACTERES
JWT_EXPIRATION=86400000

# --- CORS (origenes del frontend separados por coma) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Power BI (opcional: URLs de los dashboards publicados) ---
POWERBI_PRODUCTO_1=
POWERBI_PRODUCTO_2=
POWERBI_CLIENTE_1=
POWERBI_CLIENTE_2=
